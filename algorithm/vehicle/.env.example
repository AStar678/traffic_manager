VEHICLE_ALGORITHM_HOST=0.0.0.0
VEHICLE_ALGORITHM_PORT=8003
VEHICLE_PRELOAD_MODEL=0

PADDLE_DETECTION_DIR=/opt/PaddleDetection
PPVEHICLE_MOT_MODEL_DIR=/models/ppvehicle/mot
PPVEHICLE_ATTR_MODEL_DIR=/models/ppvehicle/attr
PPVEHICLE_TRACKER_CONFIG=/app/vehicle/config/tracker_config.yml
PPVEHICLE_DEVICE=GPU
PPVEHICLE_RUN_MODE=paddle
PPVEHICLE_CPU_THREADS=4
PPVEHICLE_ENABLE_MKLDNN=1
PPVEHICLE_SKIP_FRAME_NUM=1
PPVEHICLE_TYPE_THRESHOLD=0.7
PPVEHICLE_COLOR_THRESHOLD=0.5
PPVEHICLE_ATTRIBUTE_HISTORY=12
PPVEHICLE_MAX_BOX_AREA_RATIO=0.9

VEHICLE_MAX_UPLOAD_BYTES=524288000
VEHICLE_ALLOWED_VIDEO_ROOTS=/tmp/visiondrive-vehicle,/shared,/app/uploads
VEHICLE_ALLOWED_ORIGINS=*
