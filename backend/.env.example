# 短信服务：开发环境可改为 mock；真实短信使用 aliyun。
SMS_PROVIDER=aliyun
SMS_EXPOSE_MOCK_CODE=false
ALIYUN_REGION_ID=cn-hangzhou
ALIYUN_ACCESS_KEY_ID=replace-with-ram-access-key-id
ALIYUN_ACCESS_KEY_SECRET=replace-with-ram-access-key-secret
ALIYUN_SMS_SIGN_NAME=replace-with-approved-sign-name
ALIYUN_SMS_TEMPLATE_CODE=replace-with-approved-template-code

# 云端 MySQL（推荐通过 SSH 隧道连接，不公开数据库密码和端口）
DB_URL='jdbc:mysql://127.0.0.1:13306/visiondrive?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true'
DB_DRIVER=com.mysql.cj.jdbc.Driver
DB_USERNAME=visiondrive_app
DB_PASSWORD=replace-with-database-password
JPA_DIALECT=org.hibernate.dialect.MySQLDialect
JPA_DDL_AUTO=validate
H2_CONSOLE_ENABLED=false
JWT_SECRET=replace-with-at-least-32-byte-random-secret

DB_SSH_HOST=replace-with-server-ip
DB_SSH_USER=root
DB_SSH_LOCAL_PORT=13306
