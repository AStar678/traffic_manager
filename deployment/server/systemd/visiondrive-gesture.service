[Unit]
Description=VisionDrive Owner Gesture Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/visiondrive/app/algorithm
EnvironmentFile=%h/visiondrive/config/runtime.env
Environment=PYTHONUNBUFFERED=1
ExecStart=%h/miniconda3/envs/visiondrive/bin/python -m gesture.main
Restart=on-failure
RestartSec=3
TimeoutStartSec=120

[Install]
WantedBy=visiondrive.target

